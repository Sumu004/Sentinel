# Copy to .env and adjust. Every value below has a free default (DECISIONS.md D8) —
# the pipeline runs with none of these set.

SENTINEL_SITE_ID=dev-site-01

# Video source: "webcam" (free, default) or "rtsp" (real camera)
SENTINEL_SOURCE_KIND=webcam
SENTINEL_WEBCAM_INDEX=0
# SENTINEL_RTSP_URL=rtsp://user:pass@camera-ip:554/stream

# Detection: "motion" (free, zero-download default) or "model" (Phase 2.1 — RF-DETR/YOLO12)
SENTINEL_DETECTOR_BACKEND=motion
# SENTINEL_DETECTOR_MODEL_PATH=./models/sentinel-detector.onnx
SENTINEL_DETECT_CLASSES=person

# Event debouncing
SENTINEL_EVENT_MIN_DURATION_S=3
SENTINEL_TRACK_MAX_AGE_FRAMES=15

# Clip recording
SENTINEL_CAPTURE_FPS=15
SENTINEL_PRE_EVENT_SECONDS=3
SENTINEL_POST_EVENT_SECONDS=5

# Local storage paths
SENTINEL_DATA_DIR=./data

# Evidence chain — IPFS and public anchoring are both free but require local
# daemons/CLIs; off by default so the pipeline runs with nothing extra installed.
SENTINEL_IPFS_ENABLED=false
SENTINEL_IPFS_API_URL=http://127.0.0.1:5001
SENTINEL_ANCHOR_ENABLED=false

# Cloud backend: "sqlite" (free, default) or "dynamodb" (always-free at dev scale, D8)
SENTINEL_STORAGE_BACKEND=sqlite
SENTINEL_DYNAMODB_TABLE=SentinelEvents
AWS_REGION=us-east-1
SENTINEL_API_HOST=127.0.0.1
SENTINEL_API_PORT=8000
# Set this before exposing the backend beyond localhost — write endpoints are
# unauthenticated without it.
# SENTINEL_API_TOKEN=change-me

# Reasoning VLM (Phase 2.4): "none" (default), "qwen-local" (free), "frontier" (paid escalation)
SENTINEL_VLM_BACKEND=none
